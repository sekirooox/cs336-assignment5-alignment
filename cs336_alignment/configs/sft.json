{
    "seed": 42,
    "project_name": "cs336-assignment5",
    "name": "SFT-training-autodl",
    "batch_size": 4,
    "gradient_accumulation_steps": 64,
    "max_iters": 500,
    "start_iters": 0,
    "weight_decay": 1e-5,
    "betas": [
        0.9,
        0.98
    ],
    "eps": 1e-06,
    "max_lr": 1e-4,
    "min_lr": 1e-5,
    "warmup_iters": 50,
    "cosine_schedule_iters": 500,
    "max_grad_norm": 1.0,
    "normalize_constant": 1.0,
    "train_dataset_path": "preprocessed/gsm8k/train.jsonl",
    "test_dataset_path": "preprocessed/gsm8k/test.jsonl",
    "prompt_template_path": "cs336_alignment/prompts/r1_zero.prompt",
    "eval_interval": 25,
    "sample_size": 4,
    "save_interval": 250,
    "save_dir": "checkpoints/sft/",
    "temperature": 1.0,
    "top_p": 1.0,
    "max_tokens": 1024,
    "stop": [
        "</answer>"
    ],
    "include_stop_str_in_output": true,
    "reward_fn_name": "r1_zero_reward_fn"
}